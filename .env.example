# =============================================================
# SQAS Frontend - Example Environment Variables
# =============================================================
# Copy this file to .env and fill in the values.
# Never commit .env or .env.local to version control.

# ----- API -------------------------------------------------------
# Base URL for all backend API requests (no trailing slash)
VITE_API_BASE_URL=http://localhost:8000

# ----- Authentication -------------------------------------------
# Show a confirmation modal when the user clicks "Logout"
# Set to "true" to enable the modal, "false" to logout immediately
VITE_SHOW_LOGOUT_MODAL=true
# Inactivity timeout in minutes before auto-logout countdown begins
VITE_INACTIVITY_TIMEOUT_MINUTES=15
# Token refresh interval in minutes (proactive JWT renewal)
VITE_TOKEN_REFRESH_MINUTES=10

# Inactivity timeout in minutes before auto-logout countdown begins
VITE_INACTIVITY_TIMEOUT_MINUTES=15

# Logout Modal Content
# Customize the text displayed in the logout confirmation modal
VITE_LOGOUT_MODAL_TITLE=Sign Out
VITE_LOGOUT_MODAL_MESSAGE=Are you sure you want to sign out of your account?
VITE_LOGOUT_CANCEL_BUTTON_TEXT=Cancel
VITE_LOGOUT_CONFIRM_BUTTON_TEXT=Sign Out

# ----- App -------------------------------------------------------
VITE_APP_NAME=SQAS
VITE_APP_ENV=development
